# ── Go core (ARCH §20.1) ──
GRPC_PORT=50051
KEY_STORAGE=local            # memory | local (hsm/aws-kms/azure-kms are future backends)
KEY_STORAGE_PATH=/app/data/keys
KEY_MASTER_PASSWORD=change-me-in-production
AUDIT_STORAGE=db             # db | file
RETENTION_DAYS=2555         # ~7 years; retention/archival sweep (0 = default 7y)
LOG_LEVEL=info
DEFAULT_ALGORITHM=kyber_768
DEFAULT_SIGNATURE=dilithium_3
PQC_BACKEND=circl            # circl (default, pure-Go) | liboqs (needs a -tags liboqs build; adds Falcon)
ANCHOR_BACKEND=none          # none (default) / file / chain-adapter — opt-in audit-root notarisation
ANCHOR_PATH=/app/data/anchors.log
DB_URL=postgres://privyq:privyqpass@db:5432/privyq?sslmode=disable

# ── FastAPI gateway (ARCH §20.2) ──
CORE_ADDRESS=core:50051
SECRET_KEY=change-me-jwt-signing-key
AUTH_ENABLED=false
RATE_LIMIT_PER_SEC=100
RATE_LIMIT_BURST=200

# ── Python SDK (ARCH §20.3) ──
PRIVYQ_CORE_ADDRESS=localhost:50051
PRIVYQ_ALGORITHM=kyber_768
PRIVYQ_SIGNATURE=dilithium_3
PRIVYQ_TIMEOUT=5
PRIVYQ_AUDIT=true

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
